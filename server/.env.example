# Green server environment example.
# Use this as a reference. Set these values in PowerShell locally or in the cloud provider dashboard.

# Single admin account for the dashboard.
ADMIN_USERNAME=admin

# Production: prefer ADMIN_PASSWORD_HASH and do not set ADMIN_PASSWORD.
# Generate with:
# python -c "from app.main import hash_password; import getpass; print(hash_password(getpass.getpass()))"
ADMIN_PASSWORD_HASH=pbkdf2_sha256$260000$replace-with-generated-salt$replace-with-generated-hash

# Local development only:
# ADMIN_PASSWORD=change-this-local-password

# Required for stable signed admin sessions in production.
# Use a long random value and keep it secret.
APP_SECRET_KEY=replace-with-a-long-random-secret

# Optional. If unset, Green uses local SQLite at server/data/green.db.
# For production, set this to a managed PostgreSQL URL.
DATABASE_URL=postgresql://green_user:replace-with-password@postgres-host:5432/green
